# 智能阅卷系统 - 环境变量配置
# 复制为 .env.local 并修改实际值

# ============================================
# 应用基础配置
# ============================================
NODE_ENV=development
PORT=3001
API_PREFIX=/api/v1

# CORS 配置（允许的前端域名，逗号分隔）
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# ============================================
# 数据库配置
# ============================================
DATABASE_URL="postgresql://smartbird:smartbird_dev@localhost:5432/smartbird_dev?schema=public&connection_limit=20"
# 直接连接串（用于 Prisma introspection）
DIRECT_URL="postgresql://smartbird:smartbird_dev@localhost:5432/smartbird_dev"

# ============================================
# Redis 配置
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# BullMQ 队列配置
QUEUE_PREFIX=smartbird:queue
QUEUE_CONCURRENCY=5

# ============================================
# JWT 认证
# ============================================
# ⚠️ 生产环境必须修改！
JWT_SECRET=your-super-secret-jwt-key-minimum-32-chars-change-in-production
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=your-refresh-secret-key-different-from-jwt-secret
REFRESH_TOKEN_EXPIRES_IN=30d

# 访问令牌有效期（秒）
ACCESS_TOKEN_EXPIRE=604800  # 7天

# ============================================
# MinIO / S3 对象存储
# ============================================
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=smartbird
MINIO_REGION=us-east-1

# 如果使用 AWS S3
# S3_ENDPOINT=s3.amazonaws.com
# S3_ACCESS_KEY=your-access-key
# S3_SECRET_KEY=your-secret-key
# S3_BUCKET=your-bucket

# ============================================
# AI 服务配置（智能评分）
# ============================================

# 选项1: 阿里云通义千问（推荐用于生产）
AI_DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
AI_DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_DEFAULT_MODEL=qwen-turbo
AI_GRADING_MODEL=qwen-plus

# 选项2: 本地 Ollama（需先安装启动）
# AI_OLLAMA_BASE_URL=http://localhost:11434
# AI_DEFAULT_MODEL=qwen:7b
# AI_GRADING_MODEL=qwen:14b

# AI 评分配置
AI_GRADING_ENABLED=true
AI_GRADING_CONFIDENCE_THRESHOLD=0.8  # 置信度阈值，低于此值需人工复核
AI_GRADING_MAX_RETRIES=2
AI_GRADING_TIMEOUT=30000  # 毫秒

# ============================================
# OCR 配置（答题卡识别，可选）
# ============================================
# 使用 PaddleOCR（本地部署）
# OCR_ENGINE=paddle
# PADDLE_OCR_LANG=ch

# 或使用 Tesseract.js（轻量）
OCR_ENGINE=tesseract
TESSERACT_LANG=chi_sim+eng

# ============================================
# 企业微信通知（可选）
# ============================================
WECOM_CORP_ID=your_corp_id
WECOM_CORP_SECRET=your_corp_secret
WECOM_AGENT_ID=your_agent_id
WECOM_TOKEN=None

# ============================================
# 邮件服务（SMTP，可选）
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# ============================================
# 系统配置
# ============================================
APP_NAME="智能阅卷系统"
APP_VERSION=1.0.0

# 考试配置
EXAM_ALLOW_COPY_PASTE=false          # 禁止复制粘贴
EXAM_MAX_TAB_SWITCHES=3              # 最大切屏次数
EXAM_AUTO_SAVE_INTERVAL=30           # 自动保存间隔（秒）
EXAM_IDLE_TIMEOUT=300                # 无操作超时（秒）

# 文件上传限制
MAX_FILE_SIZE=10485760  # 10MB
ALLOWED_FILE_TYPES=jpeg,jpg,png,gif,webp,pdf,doc,docx

# ============================================
# 监控与日志
# ============================================
LOG_LEVEL=debug  # development: debug, production: info
LOG_FORMAT=json  # json 或 pretty

# Prometheus 指标
PROMETHEUS_METRICS_ENABLED=true
PROMETHEUS_PORT=9090

# Sentry 错误追踪（可选）
# SENTRY_DSN=https://your-sentry-dsn
# SENTRY_ENVIRONMENT=development

# ============================================
# 数据备份配置
# ============================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *  # 每天凌晨2点
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=smartbird-backups

# ============================================
# 缓存配置
# ============================================
CACHE_TTL_DEFAULT=3600  # 默认缓存1小时
CACHE_TTL_QUESTIONS=1800 # 题目缓存30分钟
CACHE_TTL_EXAMS=900     # 考试缓存15分钟

# ============================================
# 限流配置
# ============================================
RATE_LIMIT_WINDOW_MS=60000  # 1分钟窗口
RATE_LIMIT_MAX_REQUESTS=100  # 最大请求数

# ============================================
# 开发工具配置
# ============================================
# Prisma Studio 端口
PRISMA_STUDIO_PORT=5555

# 启用邮件验证开发模式
DEV_SKIP_EMAIL_VERIFICATION=true
DEV_ALLOW_ANY_EMAIL=true

# 测试用户（种子数据）
SEED_ADMIN_EMAIL=admin@smartbird.edu.cn
SEED_ADMIN_PASSWORD=Admin123!
