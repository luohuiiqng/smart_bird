// 与 docs/04-data-model-core.md 对齐的初版；后续迁移请走 prisma migrate。

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// 与 docs/06 中 role 概念一致
enum UserRole {
  SYSTEM_ADMIN
  SCHOOL_ADMIN
  TEACHER
}

/// 学校 / 用户启用状态
enum EntityStatus {
  ENABLED
  DISABLED
}

model School {
  id        Int            @id @default(autoincrement()) @map("id")
  name      String         @map("name")
  code      String         @unique @map("code")
  status    EntityStatus   @default(ENABLED) @map("status")
  createdAt DateTime       @default(now()) @map("created_at")
  users     User[]
  grades    Grade[]
  classes   Class[]
  subjects  Subject[]
  teachers  Teacher[]
  students  Student[]

  @@map("schools")
}

model User {
  id           Int          @id @default(autoincrement()) @map("id")
  /// `SYSTEM_ADMIN` 可为空；校管理员与教师必须绑定学校（应用层校验）
  schoolId     Int?         @map("school_id")
  school       School?      @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  username     String       @unique @map("username")
  passwordHash String       @map("password_hash")
  realName     String       @map("real_name")
  phone        String?      @map("phone")
  role         UserRole     @map("role")
  status       EntityStatus @default(ENABLED) @map("status")
  refreshTokenHash String?  @map("refresh_token_hash")
  lastLoginAt  DateTime?    @map("last_login_at")
  createdAt    DateTime     @default(now()) @map("created_at")

  @@index([schoolId], map: "users_school_id_idx")
  @@map("users")
}

model Grade {
  id        Int          @id @default(autoincrement()) @map("id")
  schoolId  Int          @map("school_id")
  school    School       @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  name      String       @map("name")
  stage     String?      @map("stage")
  status    EntityStatus @default(ENABLED) @map("status")
  createdAt DateTime     @default(now()) @map("created_at")
  classes   Class[]
  students  Student[]

  @@unique([schoolId, name], map: "grades_school_id_name_key")
  @@index([schoolId], map: "grades_school_id_idx")
  @@map("grades")
}

model Class {
  id        Int          @id @default(autoincrement()) @map("id")
  schoolId  Int          @map("school_id")
  school    School       @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  gradeId   Int          @map("grade_id")
  grade     Grade        @relation(fields: [gradeId], references: [id], onDelete: Restrict)
  name      String       @map("name")
  status    EntityStatus @default(ENABLED) @map("status")
  createdAt DateTime     @default(now()) @map("created_at")
  students  Student[]

  @@unique([gradeId, name], map: "classes_grade_id_name_key")
  @@index([schoolId], map: "classes_school_id_idx")
  @@index([gradeId], map: "classes_grade_id_idx")
  @@map("classes")
}

model Subject {
  id        Int          @id @default(autoincrement()) @map("id")
  schoolId  Int          @map("school_id")
  school    School       @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  name      String       @map("name")
  shortName String?      @map("short_name")
  type      String?      @map("type")
  status    EntityStatus @default(ENABLED) @map("status")
  createdAt DateTime     @default(now()) @map("created_at")

  @@unique([schoolId, name], map: "subjects_school_id_name_key")
  @@index([schoolId], map: "subjects_school_id_idx")
  @@map("subjects")
}

model Teacher {
  id        Int          @id @default(autoincrement()) @map("id")
  schoolId  Int          @map("school_id")
  school    School       @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  name      String       @map("name")
  gender    String?      @map("gender")
  phone     String?      @map("phone")
  email     String?      @map("email")
  status    EntityStatus @default(ENABLED) @map("status")
  createdAt DateTime     @default(now()) @map("created_at")

  @@index([schoolId], map: "teachers_school_id_idx")
  @@map("teachers")
}

model Student {
  id        Int          @id @default(autoincrement()) @map("id")
  schoolId  Int          @map("school_id")
  school    School       @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  studentNo String       @map("student_no")
  name      String       @map("name")
  gender    String?      @map("gender")
  gradeId   Int          @map("grade_id")
  grade     Grade        @relation(fields: [gradeId], references: [id], onDelete: Restrict)
  classId   Int          @map("class_id")
  class     Class        @relation(fields: [classId], references: [id], onDelete: Restrict)
  status    EntityStatus @default(ENABLED) @map("status")
  createdAt DateTime     @default(now()) @map("created_at")

  @@unique([schoolId, studentNo], map: "students_school_id_student_no_key")
  @@index([schoolId], map: "students_school_id_idx")
  @@index([gradeId], map: "students_grade_id_idx")
  @@index([classId], map: "students_class_id_idx")
  @@map("students")
}
