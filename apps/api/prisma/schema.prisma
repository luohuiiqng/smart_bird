// 与 docs/04-data-model-core.md 对齐的初版；后续迁移请走 prisma migrate。

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// 与 docs/06 中 role 概念一致
enum UserRole {
  SYSTEM_ADMIN
  SCHOOL_ADMIN
  TEACHER
}

/// 学校 / 用户启用状态
enum EntityStatus {
  ENABLED
  DISABLED
}

enum ExamStatus {
  CREATED
  MARKING
  PENDING_PUBLISH
  PUBLISHED
}

enum MarkingTaskStatus {
  TODO
  IN_PROGRESS
  DONE
  LOCKED
}

enum ScorePublishStatus {
  UNPUBLISHED
  PUBLISHED
}

model School {
  id        Int            @id @default(autoincrement()) @map("id")
  name      String         @map("name")
  code      String         @unique @map("code")
  status    EntityStatus   @default(ENABLED) @map("status")
  createdAt DateTime       @default(now()) @map("created_at")
  users     User[]
  grades    Grade[]
  classes   Class[]
  subjects  Subject[]
  teachers  Teacher[]
  students  Student[]
  exams     Exam[]
  auditLogs AuditLog[]
  markingTasks MarkingTask[]
  examStudentScores ExamStudentScore[]
  examStudentSubjectScores ExamStudentSubjectScore[]

  @@map("schools")
}

model User {
  id           Int          @id @default(autoincrement()) @map("id")
  /// `SYSTEM_ADMIN` 可为空；校管理员与教师必须绑定学校（应用层校验）
  schoolId     Int?         @map("school_id")
  school       School?      @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  username     String       @unique @map("username")
  passwordHash String       @map("password_hash")
  realName     String       @map("real_name")
  phone        String?      @map("phone")
  role         UserRole     @map("role")
  status       EntityStatus @default(ENABLED) @map("status")
  refreshTokenHash String?  @map("refresh_token_hash")
  lastLoginAt  DateTime?    @map("last_login_at")
  createdAt    DateTime     @default(now()) @map("created_at")
  auditLogs    AuditLog[]
  markingTasks MarkingTask[] @relation("MarkingTaskAssignee")

  @@index([schoolId], map: "users_school_id_idx")
  @@map("users")
}

model Grade {
  id        Int          @id @default(autoincrement()) @map("id")
  schoolId  Int          @map("school_id")
  school    School       @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  name      String       @map("name")
  stage     String?      @map("stage")
  status    EntityStatus @default(ENABLED) @map("status")
  createdAt DateTime     @default(now()) @map("created_at")
  classes   Class[]
  students  Student[]

  @@unique([schoolId, name], map: "grades_school_id_name_key")
  @@index([schoolId], map: "grades_school_id_idx")
  @@map("grades")
}

model Class {
  id        Int          @id @default(autoincrement()) @map("id")
  schoolId  Int          @map("school_id")
  school    School       @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  gradeId   Int          @map("grade_id")
  grade     Grade        @relation(fields: [gradeId], references: [id], onDelete: Restrict)
  name      String       @map("name")
  status    EntityStatus @default(ENABLED) @map("status")
  createdAt DateTime     @default(now()) @map("created_at")
  students  Student[]
  examClasses ExamClass[]

  @@unique([gradeId, name], map: "classes_grade_id_name_key")
  @@index([schoolId], map: "classes_school_id_idx")
  @@index([gradeId], map: "classes_grade_id_idx")
  @@map("classes")
}

model Subject {
  id        Int          @id @default(autoincrement()) @map("id")
  schoolId  Int          @map("school_id")
  school    School       @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  name      String       @map("name")
  shortName String?      @map("short_name")
  type      String?      @map("type")
  status    EntityStatus @default(ENABLED) @map("status")
  createdAt DateTime     @default(now()) @map("created_at")
  examSubjects ExamSubject[]

  @@unique([schoolId, name], map: "subjects_school_id_name_key")
  @@index([schoolId], map: "subjects_school_id_idx")
  @@map("subjects")
}

model Teacher {
  id        Int          @id @default(autoincrement()) @map("id")
  schoolId  Int          @map("school_id")
  school    School       @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  name      String       @map("name")
  gender    String?      @map("gender")
  phone     String?      @map("phone")
  email     String?      @map("email")
  status    EntityStatus @default(ENABLED) @map("status")
  createdAt DateTime     @default(now()) @map("created_at")

  @@index([schoolId], map: "teachers_school_id_idx")
  @@map("teachers")
}

model Student {
  id        Int          @id @default(autoincrement()) @map("id")
  schoolId  Int          @map("school_id")
  school    School       @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  studentNo String       @map("student_no")
  name      String       @map("name")
  gender    String?      @map("gender")
  gradeId   Int          @map("grade_id")
  grade     Grade        @relation(fields: [gradeId], references: [id], onDelete: Restrict)
  classId   Int          @map("class_id")
  class     Class        @relation(fields: [classId], references: [id], onDelete: Restrict)
  status    EntityStatus @default(ENABLED) @map("status")
  createdAt DateTime     @default(now()) @map("created_at")
  examScores ExamStudentScore[]
  examSubjectScores ExamStudentSubjectScore[]

  @@unique([schoolId, studentNo], map: "students_school_id_student_no_key")
  @@index([schoolId], map: "students_school_id_idx")
  @@index([gradeId], map: "students_grade_id_idx")
  @@index([classId], map: "students_class_id_idx")
  @@map("students")
}

model Exam {
  id        Int        @id @default(autoincrement()) @map("id")
  schoolId  Int        @map("school_id")
  school    School     @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  name      String     @map("name")
  examType  String     @map("exam_type")
  startDate DateTime   @map("start_date")
  endDate   DateTime   @map("end_date")
  status    ExamStatus @default(CREATED) @map("status")
  createdBy Int        @map("created_by")
  createdAt DateTime   @default(now()) @map("created_at")
  deletedAt DateTime?  @map("deleted_at")
  examClasses ExamClass[]
  examSubjects ExamSubject[]
  markingTasks MarkingTask[]
  studentScores ExamStudentScore[]
  studentSubjectScores ExamStudentSubjectScore[]
  publishStatus ScorePublishStatus @default(UNPUBLISHED) @map("publish_status")
  publishedAt DateTime? @map("published_at")
  publishNote String? @map("publish_note")

  @@index([schoolId], map: "exams_school_id_idx")
  @@index([status], map: "exams_status_idx")
  @@index([publishStatus], map: "exams_publish_status_idx")
  @@index([startDate, endDate], map: "exams_date_idx")
  @@index([deletedAt], map: "exams_deleted_at_idx")
  @@map("exams")
}

model ExamClass {
  id        Int      @id @default(autoincrement()) @map("id")
  examId    Int      @map("exam_id")
  exam      Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  classId   Int      @map("class_id")
  class     Class    @relation(fields: [classId], references: [id], onDelete: Restrict)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([examId, classId], map: "exam_classes_exam_id_class_id_key")
  @@index([classId], map: "exam_classes_class_id_idx")
  @@map("exam_classes")
}

model ExamSubject {
  id        Int      @id @default(autoincrement()) @map("id")
  examId    Int      @map("exam_id")
  exam      Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  subjectId Int      @map("subject_id")
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Restrict)
  fullScore Int      @map("full_score")
  markingCompletedAt DateTime? @map("marking_completed_at")
  createdAt DateTime @default(now()) @map("created_at")
  markingTasks MarkingTask[]
  studentScores ExamStudentSubjectScore[]

  @@unique([examId, subjectId], map: "exam_subjects_exam_id_subject_id_key")
  @@index([subjectId], map: "exam_subjects_subject_id_idx")
  @@map("exam_subjects")
}

model MarkingTask {
  id            Int               @id @default(autoincrement()) @map("id")
  schoolId      Int               @map("school_id")
  school        School            @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  examId        Int               @map("exam_id")
  exam          Exam              @relation(fields: [examId], references: [id], onDelete: Restrict)
  examSubjectId Int               @map("exam_subject_id")
  examSubject   ExamSubject       @relation(fields: [examSubjectId], references: [id], onDelete: Restrict)
  teacherId     Int               @map("teacher_id")
  teacher       User              @relation("MarkingTaskAssignee", fields: [teacherId], references: [id], onDelete: Restrict)
  status        MarkingTaskStatus @default(TODO) @map("status")
  startedAt     DateTime?         @map("started_at")
  finishedAt    DateTime?         @map("finished_at")
  createdAt     DateTime          @default(now()) @map("created_at")
  entries       MarkingTaskEntry[]

  @@unique([examSubjectId, teacherId], map: "marking_tasks_exam_subject_id_teacher_id_key")
  @@index([schoolId], map: "marking_tasks_school_id_idx")
  @@index([examId], map: "marking_tasks_exam_id_idx")
  @@index([status], map: "marking_tasks_status_idx")
  @@map("marking_tasks")
}

model MarkingTaskEntry {
  id            Int         @id @default(autoincrement()) @map("id")
  taskId        Int         @map("task_id")
  task          MarkingTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  studentId     Int         @map("student_id")
  scores        Json?       @map("scores")
  totalScore    Decimal?    @db.Decimal(8, 2) @map("total_score")
  finalSubmitted Boolean    @default(false) @map("final_submitted")
  submittedAt   DateTime?   @map("submitted_at")
  version       Int         @default(0) @map("version")
  createdAt     DateTime    @default(now()) @map("created_at")

  @@unique([taskId, studentId], map: "marking_task_entries_task_id_student_id_key")
  @@index([studentId], map: "marking_task_entries_student_id_idx")
  @@index([finalSubmitted], map: "marking_task_entries_final_submitted_idx")
  @@map("marking_task_entries")
}

model ExamStudentScore {
  id          Int      @id @default(autoincrement()) @map("id")
  schoolId    Int      @map("school_id")
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  examId      Int      @map("exam_id")
  exam        Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  studentId   Int      @map("student_id")
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Restrict)
  totalScore  Decimal  @db.Decimal(8, 2) @map("total_score")
  rankInClass Int?     @map("rank_in_class")
  rankInGrade Int?     @map("rank_in_grade")
  recalculatedAt DateTime @default(now()) @map("recalculated_at")
  createdAt   DateTime @default(now()) @map("created_at")
  subjectScores ExamStudentSubjectScore[]

  @@unique([examId, studentId], map: "exam_student_scores_exam_id_student_id_key")
  @@index([schoolId], map: "exam_student_scores_school_id_idx")
  @@index([examId], map: "exam_student_scores_exam_id_idx")
  @@index([studentId], map: "exam_student_scores_student_id_idx")
  @@map("exam_student_scores")
}

model ExamStudentSubjectScore {
  id          Int      @id @default(autoincrement()) @map("id")
  schoolId    Int      @map("school_id")
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  examId      Int      @map("exam_id")
  exam        Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  examSubjectId Int    @map("exam_subject_id")
  examSubject ExamSubject @relation(fields: [examSubjectId], references: [id], onDelete: Restrict)
  studentId   Int      @map("student_id")
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Restrict)
  totalScoreId Int     @map("total_score_id")
  totalScore  ExamStudentScore @relation(fields: [totalScoreId], references: [id], onDelete: Cascade)
  score       Decimal  @db.Decimal(8, 2) @map("score")
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([examSubjectId, studentId], map: "exam_student_subject_scores_exam_subject_id_student_id_key")
  @@index([examId], map: "exam_student_subject_scores_exam_id_idx")
  @@index([studentId], map: "exam_student_subject_scores_student_id_idx")
  @@index([totalScoreId], map: "exam_student_subject_scores_total_score_id_idx")
  @@map("exam_student_subject_scores")
}

model AuditLog {
  id         Int      @id @default(autoincrement()) @map("id")
  schoolId   Int      @map("school_id")
  school     School   @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  operatorId Int      @map("operator_id")
  operator   User     @relation(fields: [operatorId], references: [id], onDelete: Restrict)
  module     String   @map("module")
  action     String   @map("action")
  targetType String   @map("target_type")
  targetId   Int      @map("target_id")
  content    String   @map("content")
  metadata   Json?    @map("metadata")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([schoolId], map: "audit_logs_school_id_idx")
  @@index([operatorId], map: "audit_logs_operator_id_idx")
  @@index([module, action], map: "audit_logs_module_action_idx")
  @@index([targetType, targetId], map: "audit_logs_target_idx")
  @@map("audit_logs")
}
