// Prisma Schema for Smart Grading System (智能阅卷系统)
// Generated by Architect Bot
// Version: 1.0

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// 1. USER & AUTHENTICATION MODULE
// ============================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?   // 本地密码（如不使用OAuth）
  role          Role      @default(STUDENT)
  status        UserStatus @default(ACTIVE)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // 关联
  accounts      Account[]
  sessions      Session[]
  profiles      UserProfile[]
  classMembers  ClassMember[]
  createdPapers Paper[]           // 创建的试卷
  createdExams  Exam[]            // 创建的考试
  submissions   Submission[]
  gradings      Grading[]         // 人工评分记录

  @@map("users")
}

model UserProfile {
  id        String   @id @default(cuid())
  userId    String
  studentId String?  @unique // 学号
  realName  String
  gender    Gender?
  birthday  DateTime?
  phone     String?
  school    String? // 学校
  grade     String? // 年级
  parentPhone String? // 家长电话
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  TEACHER
  STUDENT
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  DELETED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

// ============================================
// 2. CLASS & ORGANIZATION MODULE
// ============================================

model Class {
  id          String   @id @default(cuid())
  name        String   // 班级名称，如"高一(1)班"
  grade       String   // 年级
  year        Int      // 学年
  teacherId   String?  // 班主任ID
  code        String?  @unique // 班级邀请码
  status      ClassStatus @default(ACTIVE)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  teacher     User?    @relation(fields: [teacherId], references: [id])
  members     ClassMember[]
  exams       Exam[]

  @@map("classes")
}

model ClassMember {
  id        String        @id @default(cuid())
  classId   String
  userId    String
  role      ClassMemberRole @default(STUDENT)
  joinedAt  DateTime      @default(now())

  class     Class         @relation(fields: [classId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([classId, userId])
  @@map("class_members")
}

enum ClassStatus {
  ACTIVE
  GRADUATED
  DISBANDED
}

enum ClassMemberRole {
  STUDENT
  CLASS_MONITOR
  TEACHER
}

// ============================================
// 3. QUESTION BANK MODULE (题库)
// ============================================

model QuestionBank {
  id          String     @id @default(cuid())
  title       String     // 题库名称
  description String?
  category    String?    // 分类，如"数学"、"英语"
  tags        String[]   // 标签，如["代数", "一元二次方程"]
  difficulty  Difficulty  @default(MEDIUM)
  createdBy   String
  isPublic    Boolean    @default(false) // 是否公开
  status      QuestionBankStatus @default(ACTIVE)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  questions   Question[]
  papers      Paper[]    // 引用了该题库的试卷

  @@map("question_banks")
}

model Question {
  id           String            @id @default(cuid())
  bankId       String
  type         QuestionType
  content      String            // 题干
  options      Json?             // 选择题选项（JSON数组）
  answer       String            // 标准答案（结构化存储）
  explanation  String?           // 解析
  difficulty   Difficulty        @default(MEDIUM)
  points       Float             @default(1.0) // 分值
  tags         String[]          // 标签（用于知识点标记）
  imageUrl     String?           // 题目图片（如有）
  audioUrl     String?           // 听力材料
  videoUrl     String?           // 视频题目
  metadata     Json?             // 扩展元数据
  version      Int               @default(1)
  status       QuestionStatus    @default(ACTIVE)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  bank         QuestionBank      @relation(fields: [bankId], references: [id], onDelete: Cascade)
  paperItems   PaperItem[]
  aiScores     AIScore[]

  @@map("questions")
}

model Paper {
  id          String     @id @default(cuid())
  title       String
  description String?
  bankId      String?
  totalScore  Float      @default(0) // 总分（自动计算）
  timeLimit   Int?       // 考试时长（分钟）
  shuffle     Boolean    @default(false) // 是否随机打乱题目
  isPublic    Boolean    @default(false)
  status      PaperStatus @default(DRAFT)
  createdBy   String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  bank        QuestionBank? @relation(fields: [bankId], references: [id])
  items       PaperItem[]
  exams       Exam[]

  @@map("papers")
}

model PaperItem {
  id        String   @id @default(cuid())
  paperId   String
  questionId String
  order     Int      // 题目顺序
  score     Float    // 该题分值（可选，覆盖默认分值）
  createdAt DateTime @default(now())

  paper     Paper    @relation(fields: [paperId], references: [id], onDelete: Cascade)
  question  Question @relation(fields: [questionId], references: [id])

  @@unique([paperId, questionId])
  @@map("paper_items")
}

enum QuestionType {
  SINGLE_CHOICE      // 单选题
  MULTIPLE_CHOICE    // 多选题
  TRUE_FALSE         // 判断题
  FILL_IN_BLANK      // 填空题
  SHORT_ANSWER       // 简答题
  ESSAY             // 论述题
  COMPREHENSION     // 阅读理解
  LISTENING         // 听力题
  UPLOAD            // 上传题（图片/文件）
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum QuestionBankStatus {
  ACTIVE
  ARCHIVED
  DELETED
}

enum QuestionStatus {
  ACTIVE
  REVIEWING
  REJECTED
  ARCHIVED
}

enum PaperStatus {
  DRAFT       // 草稿
  PUBLISHED   // 已发布
  FINISHED    // 已结束
  ARCHIVED    // 已归档
}

// ============================================
// 4. EXAM MODULE (考试核心)
// ============================================

model Exam {
  id          String        @id @default(cuid())
  title       String
  description String?
  paperId     String
  classIds    String[]      // 参加的班级ID数组
  startTime   DateTime      // 考试开始时间
  endTime     DateTime      // 考试结束时间
  duration    Int           // 考试时长（分钟）
  status      ExamStatus    @default(SCHEDULED)
  allowReview Boolean       @default(true) // 是否允许考后查看答案
  randomize   Boolean       @default(false) // 是否随机抽题
  maxAttempts Int           @default(1) // 最多尝试次数
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  paper       Paper         @relation(fields: [paperId], references: [id])
  sessions    ExamSession[]
  statistics ExamStatistic[]

  @@map("exams")
}

model ExamSession {
  id           String        @id @default(cuid())
  examId       String
  userId       String
  token        String        @unique // 考试令牌
  startedAt    DateTime      @default(now())
  submittedAt  DateTime?
  lastActivity DateTime?     // 最后活动时间
  durationUsed Int           @default(0) // 已用时（秒）
  ipAddress    String?
  userAgent    String?
  status       ExamStatus    @default(IN_PROGRESS)

  exam         Exam          @relation(fields: [examId], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [userId], references: [id])
  answers      Answer[]
  submission   Submission?

  @@unique([examId, userId])
  @@map("exam_sessions")
}

model Answer {
  id         String   @id @default(cuid())
  sessionId  String
  questionId String
  content    String?  // 学生答案文本
  images     String[] // 上传的图片URL数组（手写题、画图题）
  audioUrl   String?  // 录音URL
  videoUrl   String?  // 录像URL
  score      Float?   // 得分
  timeSpent  Int      // 答题耗时（秒）
  order      Int      // 答题顺序
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  session    ExamSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  question   Question    @relation(fields: [questionId], references: [id])
  grading    Grading?
  aiScore    AIScore?

  @@unique([sessionId, questionId])
  @@map("answers")
}

model Submission {
  id              String    @id @default(cuid())
  sessionId       String    @unique
  totalScore      Float     // 总分
  objectiveScore  Float     // 客观题得分
  subjectiveScore Float?    // 主观题得分
  aiScore         Float?    // AI评分
  manualScore     Float?    // 人工评分
  subjectiveCount Int       @default(0) // 主观题数量
  gradedCount     Int       @default(0) // 已评分数量
  finishedAt      DateTime  // 提交时间
  durationUsed    Int       // 总用时（秒）

  session  ExamSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  gradings Grading[]

  @@map("submissions")
}

model Grading {
  id         String   @id @default(cuid())
  submissionId String
  answerId   String
  graderId   String   // 评分人
  score      Float    // 得分
  feedback   String?  // 反馈意见
  isFinal    Boolean  @default(false) // 是否为最终确认评分
  gradedAt   DateTime @default(now())

  submission Submission @relation(fields: [submissionId], references: [id])
  answer    Answer     @relation(fields: [answerId], references: [id])
  grader    User       @relation(fields: [graderId], references: [id])

  @@map("gradings")
}

model AIScore {
  id         String   @id @default(cuid())
  answerId   String
  model      String   // 使用的模型，如"qwen-7b"
  score      Float
  reasoning  String?  // AI评分理由
  confidence Float    // 置信度 0-1
  tokensUsed Int      // Token消耗
  latency    Int      // 响应时间(ms)
  createdAt  DateTime @default(now())

  answer Answer @relation(fields: [answerId], references: [id], onDelete: Cascade)

  @@map("ai_scores")
}

enum ExamStatus {
  SCHEDULED    // 待开始
  IN_PROGRESS  // 进行中
  GRADING      // 批改中
  FINISHED     // 已结束
  ARCHIVED     // 已归档
}

// ============================================
// 5. ANALYTICS MODULE (分析报表)
// ============================================

model ExamStatistic {
  id           String   @id @default(cuid())
  examId       String
  totalStudents Int     // 总人数
  attended     Int      // 参加人数
  averageScore Float    // 平均分
  maxScore     Float    // 最高分
  minScore     Float    // 最低分
  medianScore  Float    // 中位数
  stdDev       Float    // 标准差
  passingRate  Float    // 及格率
  excellentRate Float   // 优秀率
  scoreDistribution Json // 分数分布直方图
  questionStats Json    // 各题目统计
  updatedAt    DateTime @default(now())

  exam Exam @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@unique([examId])
  @@map("exam_statistics")
}

model StudentAnalytics {
  id        String   @id @default(cuid())
  userId    String
  examId    String?
  date      DateTime @default(now()) // 统计日期

  // 成绩维度
  totalScore      Float?
  averageScore    Float?  // 平均分
  rankInClass     Int?     // 班级排名
  rankInGrade     Int?     // 年级排名

  // 知识点掌握度
  knowledgeMastery Json   // {"algebra": 0.85, "geometry": 0.72, ...}

  // 能力维度
  abilityScores Json      // {"计算能力": 8.5, "逻辑思维": 7.2, ...}

  // 趋势数据
  scoreTrend Json         // 历史成绩曲线点集

  updatedAt DateTime @updatedAt

  @@unique([userId, examId])
  @@map("student_analytics")
}

// ============================================
// 6. SYSTEM MODULE (系统)
// ============================================

model SystemConfig {
  id    String  @id @default(cuid())
  key   String  @unique
  value String  @db.Text
  type  String? // string, number, boolean, json
  description String?
  updatedAt DateTime @updatedAt

  @@map("system_configs")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String   // 操作类型，如"exam.create", "user.login"
  resource  String?  // 资源类型
  resourceId String? // 资源ID
  details   String?  @db.Text // 详细日志（JSON字符串）
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@map("audit_logs")
}

// ============================================
// 7. AI & ML MODULE
// ============================================

model AIPromptTemplate {
  id          String   @id @default(cuid())
  name        String
  type        String   // "grading" | "analysis" | "recommendation"
  prompt      String   @db.Text // 提示词模板
  variables   String[] // 可用的变量列表
  model       String   // 指定模型
  temperature Float    @default(0.7)
  maxTokens   Int      @default(1024)
  isActive    Boolean  @default(true)
  version     Int      @default(1)
  createdAt   DateTime @default(now())

  @@map("ai_prompt_templates")
}

model AIModelConfig {
  id        String   @id @default(cuid())
  name      String   // 如 "qwen-7b", "qwen-14b", "gpt-4"
  provider  String   // "local" | "openai" | "dashscope"
  apiUrl    String?
  apiKey    String?  @db.Text
  isDefault Boolean  @default(false)
  weight    Float    @default(1.0) // 权重（用于融合多个模型）
  createdAt DateTime @default(now())

  @@map("ai_model_configs")
}

// ============================================
// 8. NOTIFICATION MODULE
// ============================================

model Notification {
  id        String          @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  content   String          @db.Text
  data      Json?           // 附加数据
  isRead    Boolean         @default(false)
  readAt    DateTime?
  createdAt DateTime        @default(now())

  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model NotificationTemplate {
  id    String   @id @default(cuid())
  type  NotificationType
  title String
  content String @db.Text // 支持变量替换的模板
  channel String  // "wecom" | "email" | "sms"

  @@map("notification_templates")
}

enum NotificationType {
  EXAM_PUBLISHED       // 考试发布
  EXAM_STARTING        // 考试即将开始
  EXAM_REMINDER        // 考试提醒
  EXAM_FINISHED        // 考试结束
  GRADE_PUBLISHED      // 成绩发布
  HOMEWORK_ASSIGNED    // 作业布置
  ANNOUNCEMENT         // 系统公告
  SYSTEM               // 系统通知
}

// ============================================
// 9. FILE STORAGE (MinIO/S3)
// ============================================

model FileRecord {
  id        String   @id @default(cuid())
  filename  String   // 原始文件名
  storedAs  String   // 存储后的key
  mimeType  String
  size      Int      // 字节
  url       String?  // 访问URL
  bucket    String   // 存储桶
  uploadedBy String
  purpose   String?  // "question_image" | "answer_image" | "avatar"
  metadata  Json?    // 额外元数据
  expiresAt DateTime? // 过期时间（如有）
  createdAt DateTime @default(now())

  @@map("file_records")
}

