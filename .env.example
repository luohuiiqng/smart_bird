# 复制为项目根目录 `.env` 后按需修改；不要提交真实 `.env`。
# API 从 `apps/api` 启动时会通过 ConfigModule 加载仓库根目录 `.env`（见 `apps/api/src/app.module.ts`）。

# PostgreSQL（与 docker-compose 中一致）
DATABASE_URL="postgresql://app:app@localhost:5432/exam_sys?schema=public"

# Redis
REDIS_URL="redis://127.0.0.1:6379/0"

# MinIO（S3 兼容；应用层集成在后续 files 模块实现）
MINIO_ENDPOINT=127.0.0.1
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=exam-files

# API
PORT=3000
API_PREFIX=api/v1

# JWT 等安全项在实现 auth 模块时补全，勿使用示例值上生产
# JWT_SECRET=
# JWT_EXPIRES_IN=2h

# JWT
JWT_ACCESS_SECRET=replace_with_secure_access_secret
JWT_REFRESH_SECRET=replace_with_secure_refresh_secret
JWT_ACCESS_EXPIRES_IN=2h
JWT_REFRESH_EXPIRES_IN=7d

# Seed（仅开发环境，生产请禁用默认口令）
SEED_SCHOOL_CODE=DEMO_SCHOOL_001
SEED_SCHOOL_NAME=示例学校
SEED_SYSTEM_ADMIN_USERNAME=sysadmin
SEED_SYSTEM_ADMIN_PASSWORD=Sysadmin123
SEED_SCHOOL_ADMIN_USERNAME=schooladmin
SEED_SCHOOL_ADMIN_PASSWORD=Schooladmin123
